{
  "family": "shareshot-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "executionRoleArn": "arn:aws:iam::431754448027:role/ecsTaskExecutionRole",
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "arq-worker",
      "image": "431754448027.dkr.ecr.eu-north-1.amazonaws.com/shareshot1:latest",
      "essential": true,
      "command": ["arq", "worker.WorkerSettings"],
      "environment": [
        {
          "name": "DB_HOST",
          "value": "your-rds-endpoint.aws.com"
        },
        {
          "name": "REDIS_URL2",
          "value": "your-elasticache-endpoint"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/shareshot-worker",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "worker"
        }
      }
    }
  ]
}
